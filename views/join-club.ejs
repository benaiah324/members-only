<%- include('partials/header', { pageTitle: 'Join the Club' }) %>

<section class="form-section">
  <h1>Join the Club</h1>
  <p class="subtitle">Whisper the secret passcode to the bouncer at the door.</p>

  <% if (errors && errors.length) { %>
    <ul class="form-errors">
      <% errors.forEach(function(err) { %>
        <li><%= err.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/join-club" method="POST" class="form" novalidate>
    <div class="form-group">
      <label for="passcode">Secret passcode</label>
      <input
        type="password"
        id="passcode"
        name="passcode"
        required
        autocomplete="off"
      />
    </div>

    <button type="submit" class="btn btn-primary btn-block">Enter the club</button>
  </form>
</section>

<%- include('partials/footer') %>
