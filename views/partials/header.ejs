<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %>Members Only</title>
    <script>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        var theme = stored === 'light' || stored === 'dark' ? stored : prefersLight ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">Members Only</a>

        <div class="header-actions">
          <button
            type="button"
            class="btn btn-ghost theme-toggle"
            id="theme-toggle"
            aria-label="Toggle light and dark theme"
            title="Toggle theme"
          >
            <span class="theme-icon theme-icon-light" aria-hidden="true">☀</span>
            <span class="theme-icon theme-icon-dark" aria-hidden="true">☾</span>
            <span class="theme-label theme-label-light">Light</span>
            <span class="theme-label theme-label-dark">Dark</span>
          </button>

          <button
            type="button"
            class="nav-toggle"
            id="nav-toggle"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="main-nav"
          >
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
          </button>
        </div>

        <nav class="nav" id="main-nav">
          <% if (user) { %>
            <span class="nav-user">Hi, <%= user.firstName %></span>
            <div class="nav-badges">
              <% if (user.isAdmin) { %>
                <span class="badge badge-admin">Admin</span>
              <% } %>
              <% if (user.membershipStatus) { %>
                <span class="badge badge-member">Member</span>
              <% } %>
            </div>
            <% if (!user.membershipStatus) { %>
              <a href="/join-club" class="nav-link">Join the Club</a>
            <% } %>
            <a href="/messages/new" class="nav-link">
              <span class="nav-text-long">Create a new message</span>
              <span class="nav-text-short">New message</span>
            </a>
            <form action="/logout" method="POST" class="nav-form">
              <button type="submit" class="btn btn-ghost btn-nav">Log out</button>
            </form>
          <% } else { %>
            <a href="/login" class="nav-link">Log in</a>
            <a href="/sign-up" class="btn btn-primary btn-nav">Sign up</a>
          <% } %>
        </nav>
      </div>
    </header>

    <main class="container main-content">
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
